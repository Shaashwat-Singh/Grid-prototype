# ============================================================
# GRID Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.
# ============================================================

# --- Alpaca Paper Trading ---
# Sign up free at https://alpaca.markets
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- OpenAI (Agent Reasoning) ---
# Used for agent LLM reasoning. Replace with any compatible provider.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# --- GRID Configuration ---
# Enforcement mode: "strict" (fail-closed) or "audit" (log-only, for testing)
GRID_ENFORCEMENT_MODE=strict

# Audit log path (append-only)
GRID_AUDIT_LOG_PATH=./audit_logs/grid_audit.jsonl

# Maximum delegation depth allowed
GRID_MAX_DELEGATION_DEPTH=2

# Enable prompt injection detection
GRID_INJECTION_DETECTION=true
